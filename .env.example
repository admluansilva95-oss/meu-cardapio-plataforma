# Copie este arquivo para ".env.local" na raiz do projeto e preencha com os valores do Supabase:
# Dashboard → Project Settings → API

# URL pública do projeto (ex.: https://xxxx.supabase.co)
# Use a URL da API (Settings → API → Project URL), não a connection string Postgres/pooler.
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (segura para o browser com RLS ativo)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: chave service_role — NUNCA exponha no client; use só em Route Handlers / server com cuidado
# SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app (checkout Stripe, redirect pós-confirmação de e-mail → /auth/callback)
# Deve coincidir com a URL em que o Next roda (porta inclusa). Sem barra no final.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# No Supabase: Authentication → URL Configuration → adicione em Redirect URLs:
#   http://localhost:3000/auth/callback
# (e a URL de produção equivalente ao publicar)

# Stripe — Price IDs dos planos (Dashboard → Products → Prices)
# NEXT_PUBLIC_STRIPE_PRICE_ESSENCIAL=price_xxx
# NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Webhook endpoint: POST /api/webhooks/stripe
# Local: stripe listen --forward-to localhost:3000/api/webhooks/stripe
