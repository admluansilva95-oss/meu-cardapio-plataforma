# Copie para um destes ficheiros (o Playwright carrega-os antes do `webServer`; o Next não lê `.env.e2e` sozinho):
#   - `.env.e2e` na raiz do repo, ou
#   - `tests/e2e/.env.e2e` (mesmo conteúdo; útil para manter E2E junto dos testes)
# Alternativa: defina tudo em `.env.local` na raiz.
#
# Obrigatório para os testes de integração (login + /admin + logout):
E2E_EMAIL=
E2E_PASSWORD=

# Mesmos valores que em `.env.local` / Vercel — necessários ao cliente Supabase no browser:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: tenant explícito em `/admin?slug=...`
# E2E_RESTAURANT_SLUG=
